# ============================================
# LUFUS PROJECT - ENVIRONMENT CONFIGURATION
# ============================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES
# NUNCA COMMIT O .env AO VERSIONAMENTO
# ============================================

# ============================================
# DATABASE
# ============================================
POSTGRES_USER=lufus
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_DB=lufus
POSTGRES_PORT=5432

# Connection string
DATABASE_URL=postgresql://lufus:sua_senha_aqui@localhost:5432/lufus

# ============================================
# SECURITY
# ============================================
# Gere com: openssl rand -hex 32
PASSWORD_PEPPER=gere_com_openssl_rand_hex_32

# Gere com: openssl rand -hex 64
LUFUS_API_KEY=

# ============================================
# ENVIRONMENT
# ============================================
# development | production
NODE_ENV=development

# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# ============================================
# PRODUÇÃO - SSL OBRIGATÓRIO
# ============================================
# NODE_ENV=production
# DATABASE_URL=postgresql://lufus:senha@host:5432/lufus?sslmode=require
