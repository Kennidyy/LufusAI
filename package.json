{
  "name": "lufus_project",
  "module": "index.ts",
  "imports": {
    "@/*": "./src/*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/validator": "^13.15.10",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "dev": "bun run src/cli.ts",
    "cli": "bun run src/cli.ts",
    "client": "bun run src/client.ts",
    "db:push": "bun run drizzle-kit push",
    "db:generate": "bun run drizzle-kit generate",
    "docker:up": "docker compose up -d postgres",
    "docker:push": "docker compose run --rm app bunx drizzle-kit push",
    "docker:cli": "docker compose run --rm app bun run src/cli.ts"
  },
  "type": "module",
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@types/axios": "^0.14.4",
    "@types/redis": "^4.0.11",
    "axios": "^1.15.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.9",
    "redis": "^5.11.0",
    "validator": "^13.15.35"
  }
}
